# Mappls (MapMyIndia) — https://developer.mappls.com
MAPPLS_API_KEY=your_mappls_api_key_here
MAPPLS_CLIENT_ID=your_client_id_here
MAPPLS_CLIENT_SECRET=your_client_secret_here

# HERE Traffic — https://developer.here.com
HERE_API_KEY=your_here_api_key_here

# Ola Maps — https://maps.olacabs.com/devportal
OLA_MAPS_API_KEY=your_ola_maps_api_key_here

# OpenWeatherMap — https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Model config
MODEL_CHECKPOINT_PATH=models/checkpoints/best_model.pt
CONFIG_PATH=config/config.yaml
LOG_LEVEL=INFO
